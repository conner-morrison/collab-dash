# Copy to .env and adjust for your environment.
ENVIRONMENT=development

# SQLite (default, zero-setup):
DATABASE_URL=sqlite:///./dashboard.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/dashboard

JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_ORIGIN=http://localhost:3000

# Admin console — an admin user is auto-provisioned on startup when
# ADMIN_PASSWORD is set. Keep the password out of source control.
ADMIN_EMAIL=admin@collabdash.com
ADMIN_PASSWORD=

# Realtime bus: "memory" (single instance) or "redis" (multi-instance fan-out)
BROADCASTER=memory
REDIS_URL=redis://localhost:6379/0

# Email (SendGrid). When both are set, verification/reset emails are sent for
# real; otherwise the link is just logged (dev). EMAIL_FROM must be a
# SendGrid-verified sender (Single Sender or a verified domain).
SENDGRID_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Collab Dashboard
